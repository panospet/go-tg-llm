TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# At least one of the following must be set. Unset providers are simply
# disabled at runtime; their commands will report "Provider not configured".
PERPLEXITY_API_KEY=your-perplexity-api-key
GEMINI_API_KEY=your-gemini-api-key

# Optional model overrides. Leave empty to use defaults
# (perplexity: "sonar", gemini: "gemini-2.5-flash").
PERPLEXITY_MODEL=
GEMINI_MODEL=
